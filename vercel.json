{
  "builds": [
    {
      "src": "api/post_scheduler.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/post_scheduler",
      "dest": "api/post_scheduler.py"
    }
  ],
  "crons": [
    {
      "path": "/api/post_scheduler",
      "schedule": "*/30 * * * *"
    }
  ]
}
